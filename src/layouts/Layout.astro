---
export interface Props {
  title?: string;
  canonicalPath?: string;
  frontmatter?: {
    title?: string;
    canonicalPath?: string;
  };
}

const { title, canonicalPath = '', frontmatter } = Astro.props;
// For Markdown files, frontmatter is available as well
const pageTitle = title || frontmatter?.title || 'RKeelan.com';
const pagePath = canonicalPath || frontmatter?.canonicalPath || '';
const cssFiles = ["/css/styles.css"];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        var theme = localStorage.getItem("theme-preference");
        var root = document.documentElement;
        if (theme === "light" || theme === "dark") {
          root.setAttribute("data-theme", theme);
        } else {
          root.removeAttribute("data-theme");
        }
      }());
    </script>
    <link rel="canonical" href={`https://www.rkeelan.com/${pagePath}`}>
    <link rel='shortcut icon' type='image/x-icon' href='/favicon.ico' />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32">
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16">
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5">
    <link rel="manifest" href="/manifest.json">
    {cssFiles.map(cssFile => (
        <link rel="stylesheet" href={cssFile}>
    ))}

    <!-- Person JSON-LD -->
    <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Richard Keelan",
      "url": "https://www.rkeelan.com",
      "sameAs": [
        "https://github.com/rkeelan",
        "https://rkeelan.github.io",
        "https://twitter.com/r_keelan",
        "https://www.linkedin.com/in/richard-keelan-79793611/"
      ],
      "jobTitle": "Software Engineer",
      "knowsAbout": ["AI", "Programming", "Writing", "Software Engineering", "Embedded Systems"],
      "memberOf": {
        "@type": "Organization",
        "name": "Keel Inc",
        "url": "https://github.com/Keel-Inc"
      },
      "affiliation": {
        "@type": "Organization",
        "name": "CompactFrameFormat",
        "url": "https://github.com/CompactFrameFormat"
      }
    })}
    </script>
</head>
<body>
    <header>
        <h1>{pageTitle}</h1>
    </header>
    <nav>
        <ul class="menu-navigation-container">
            <li><a href="/index.html">Home</a></li>
            <li class="nav-spacer"></li>
            <li class="theme-menu">
                <button class="theme-trigger" id="theme-trigger" type="button" aria-expanded="false" aria-haspopup="true" aria-controls="theme-options" aria-label="Theme: system">
                    <span class="theme-trigger-icon" aria-hidden="true"></span>
                </button>
                <div class="theme-options" id="theme-options" hidden>
                    <button class="theme-option" data-theme-option="system" type="button" aria-label="Use system theme">
                        <span class="theme-option-icon" aria-hidden="true"></span>
                    </button>
                    <button class="theme-option" data-theme-option="light" type="button" aria-label="Use light theme">
                        <span class="theme-option-icon" aria-hidden="true"></span>
                    </button>
                    <button class="theme-option" data-theme-option="dark" type="button" aria-label="Use dark theme">
                        <span class="theme-option-icon" aria-hidden="true"></span>
                    </button>
                </div>
            </li>
        </ul>
    </nav>
    <main class="content">
        <slot />
    </main>
    <footer>
        &copy; 2025 RKeelan. All rights reserved.
    </footer>
    <script is:inline>
      (function () {
        var themeMenu = document.querySelector(".theme-menu");
        var trigger = document.getElementById("theme-trigger");
        var options = document.getElementById("theme-options");
        var themeButtons = document.querySelectorAll("[data-theme-option]");
        var mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
        var storageKey = "theme-preference";
        var root = document.documentElement;
        var themeIcons = {
          system: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="5" width="16" height="11" rx="2"></rect><path d="M10 19h4"></path><path d="M12 16v3"></path></svg>',
          light: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4.5"></circle><path d="M12 2.5v2.25"></path><path d="M12 19.25v2.25"></path><path d="M21.5 12h-2.25"></path><path d="M4.75 12H2.5"></path><path d="M18.72 5.28l-1.59 1.59"></path><path d="M6.87 17.13l-1.59 1.59"></path><path d="M18.72 18.72l-1.59-1.59"></path><path d="M6.87 6.87L5.28 5.28"></path></svg>',
          dark: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M 20.948 19.016 L 19.997 19.845 L 19.370 20.270 L 18.622 20.695 L 17.644 21.145 L 16.444 21.570 L 16.091 21.645 L 14.673 21.870 L 13.475 21.925 L 12.294 21.850 L 11.384 21.695 L 10.256 21.395 L 9.206 20.995 L 8.330 20.570 L 7.403 19.995 L 6.559 19.347 L 5.655 18.497 L 4.805 17.472 L 4.080 16.347 L 3.555 15.270 L 3.180 14.295 L 2.955 13.441 L 2.780 12.331 L 2.700 11.431 L 2.700 10.594 L 2.750 10.406 L 2.750 9.909 L 2.955 8.684 L 3.202 7.764 L 3.680 6.505 L 4.130 5.628 L 4.580 4.903 L 5.303 3.959 L 6.034 3.178 L 7.053 2.305 L 8.078 1.655 L 8.125 1.669 L 7.680 2.430 L 7.230 3.355 L 6.830 4.381 L 6.580 5.233 L 6.352 6.378 L 6.255 7.228 L 6.250 9.056 L 6.430 10.316 L 6.630 11.094 L 6.880 11.944 L 7.205 12.744 L 7.605 13.545 L 8.130 14.422 L 9.127 15.695 L 10.153 16.695 L 11.478 17.670 L 12.255 18.120 L 13.330 18.623 L 14.633 19.045 L 15.634 19.273 L 16.359 19.375 L 16.909 19.425 L 18.297 19.425 L 19.161 19.348 L 20.909 18.977 Z"></path></svg>'
        };

        function getStoredTheme() {
          return localStorage.getItem(storageKey) || "system";
        }

        function getResolvedTheme(theme) {
          return theme === "system" ? (mediaQuery.matches ? "dark" : "light") : theme;
        }

        function applyTheme(theme) {
          if (theme === "system") {
            root.removeAttribute("data-theme");
          } else {
            root.setAttribute("data-theme", getResolvedTheme(theme));
          }

          themeButtons.forEach(function (button) {
            var isActive = button.getAttribute("data-theme-option") === theme;
            button.classList.toggle("is-active", isActive);
            button.setAttribute("aria-pressed", isActive ? "true" : "false");
            button.querySelector(".theme-option-icon").innerHTML = themeIcons[button.getAttribute("data-theme-option")];
          });

          trigger.querySelector(".theme-trigger-icon").innerHTML = themeIcons[theme];
          trigger.setAttribute("aria-label", "Theme: " + theme);
        }

        function persistTheme(theme) {
          if (theme === "system") {
            localStorage.removeItem(storageKey);
          } else {
            localStorage.setItem(storageKey, theme);
          }
          applyTheme(theme);
        }

        function closeMenu() {
          options.hidden = true;
          trigger.setAttribute("aria-expanded", "false");
        }

        trigger.addEventListener("click", function () {
          if (options.hidden) {
            options.hidden = false;
            trigger.setAttribute("aria-expanded", "true");
          } else {
            closeMenu();
          }
        });

        themeButtons.forEach(function (button) {
          button.addEventListener("click", function () {
            persistTheme(button.getAttribute("data-theme-option"));
            closeMenu();
          });
        });

        document.addEventListener("click", function (event) {
          if (!themeMenu.contains(event.target)) {
            closeMenu();
          }
        });

        document.addEventListener("keydown", function (event) {
          if (event.key === "Escape") {
            closeMenu();
            trigger.blur();
          }
        });

        if (typeof mediaQuery.addEventListener === "function") {
          mediaQuery.addEventListener("change", function () {
            if (getStoredTheme() === "system") {
              applyTheme("system");
            }
          });
        }

        applyTheme(getStoredTheme());
      }());
    </script>
</body>
</html>